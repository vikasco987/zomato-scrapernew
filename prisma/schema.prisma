// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model FoodImage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  foodName     String
  userId       String?  // 🔥 Link to Restaurant ID
  originalUrl  String?
  cloudinaryUrl String?  // 🔥 The Pro CDN URL
  localPath    String?
  status       String   @default("pending") // pending, completed, failed
  confidence   Int      @default(0)     // AI Confidence Score (0-100)
  isManual     Boolean  @default(false) // Whether user overrode this image
  retryCount   Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([foodName, userId])
}

model ScraperJob {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  status         String   @default("queued") // queued, processing, completed, failed
  totalItems     Int      @default(0)
  processedCount Int      @default(0)
  failedCount    Int      @default(0)
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
model MenuItem {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  price        Float
  description  String?
  category     String
  image        String?
  source       String   // zomato / swiggy
  restaurantId String   @db.ObjectId
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  status               String     @default("pending") // 'pending', 'completed', 'failed'
  stabilityStatus      String     @default("PENDING") // 'PENDING', 'LIVE', 'REMOVED', 'STABLE'
  history              Json?      // Lifecycle log: [{status: 'LIVE', time: '...'}, ...]
  retries              Int        @default(0)
  lastStabilityCheck   DateTime?
  uploadedAt           DateTime?
  retryCount           Int        @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Restaurant {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  slug         String
  url          String?
  source       String   // zomato / swiggy
  menuItems    MenuItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RestaurantLead {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  outletName   String?
  phone        String   @unique
  email        String?
  address      String?
  source       String   // Zomato, Google
  location     String
  url          String?
  confidence   Int      @default(0)
  sessionId    String?  @db.ObjectId
  createdAt    DateTime @default(now())
}

model ScrapingSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  location  String
  source    String
  count     Int      @default(0)
  status    String   @default("processing") // processing, completed
  createdAt DateTime @default(now())
}
