// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model FoodImage {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  foodName     String
  userId       String?  // 🔥 Link to Restaurant ID
  originalUrl  String?
  cloudinaryUrl String?  // 🔥 The Pro CDN URL
  localPath    String?
  status       String   @default("pending") // pending, completed, failed
  confidence   Int      @default(0)     // AI Confidence Score (0-100)
  isManual     Boolean  @default(false) // Whether user overrode this image
  retryCount   Int      @default(0)
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([foodName, userId])
}

model ScraperJob {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  status         String   @default("queued") // queued, processing, completed, failed
  totalItems     Int      @default(0)
  processedCount Int      @default(0)
  failedCount    Int      @default(0)
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
