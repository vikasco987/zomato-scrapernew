{
  "name": "zomato-scraper",
  "version": "1.0.0",
  "description": "",
  "main": "electron-main.js",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/server.js",
    "dev": "npx tsc && concurrently \"node dist/index.js\" \"node dist/server.js\"",
    "electron": "npx tsc && electron .",
    "dist": "npx tsc && electron-builder",
    "db:push": "npx prisma db push",
    "db:studio": "npx prisma studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@prisma/client": "^6.4.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/puppeteer": "^5.4.7",
    "axios": "^1.13.6",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "prisma": "^6.4.1",
    "puppeteer": "^24.40.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "better-sqlite3": "^12.8.0",
    "cloudinary": "^2.9.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "multer": "^2.1.1",
    "openai": "^4.20.1",
    "p-limit": "^7.3.0",
    "puppeteer": "^21.5.2",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.kravy.aiscraper",
    "productName": "Kravy AI Scraper",
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "electron-main.js",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
